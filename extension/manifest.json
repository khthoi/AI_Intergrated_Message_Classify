{
  "manifest_version": 3,
  "name": "AutoMSToolAI - Messenger Assistant",
  "version": "1.0.0",
  "description": "Tự động đọc tin nhắn Messenger và tổng hợp đơn hàng bằng AI.",
  "permissions": ["activeTab", "storage", "alarms", "scripting", "tabs", "downloads"],
  "host_permissions": ["https://www.messenger.com/*", "http://localhost/*"],
  "content_scripts": [
    {
      "matches": ["https://www.messenger.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AutoMSToolAI"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
